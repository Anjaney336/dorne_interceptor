# =============================================================================
# Drone Interceptor — Environment Variable Reference
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# DO NOT commit .env to version control.
#
# Feature flags follow the DRONE_FEATURE_<NAME> naming convention.
# Truthy values:  1  true  yes  on
# Falsy values:   0  false no   off  (or simply unset — defaults to FALSE)
#
# Rollback procedure
# ------------------
# 1. Instant (no redeploy):   Set DRONE_FEATURE_SPOOFING=false on the server
#                             and send SIGHUP / restart uvicorn workers.
# 2. Code rollback:           revert spoof_service.py import in telemetry_api.py.
#                             Core endpoints (/mission/start, /validate, /stream)
#                             are NEVER changed — only a middleware hook is added.
# =============================================================================


# ── Feature Flags ─────────────────────────────────────────────────────────────

# DRONE_FEATURE_SPOOFING
#   Master toggle for the Spoof Injection module (SpoofService).
#   When OFF:  apply_spoof() is a zero-overhead passthrough — pipeline unchanged.
#   When ON:   Gaussian adversarial noise / frame corruption injected per-frame.
#   Default:   false  (safe-off principle for production)
DRONE_FEATURE_SPOOFING=false

# DRONE_FEATURE_MATRIX_VALIDATION
#   Enable the 12-case validation matrix on /validate.
#   Default:   false
DRONE_FEATURE_MATRIX_VALIDATION=false

# DRONE_FEATURE_CINEMATIC_EXPORT
#   Auto-export cinematic MP4 demo after each mission.
#   Default:   true
DRONE_FEATURE_CINEMATIC_EXPORT=true


# ── Application Settings ──────────────────────────────────────────────────────

# FastAPI bind address
HOST=0.0.0.0
PORT=8000

# Streamlit dashboard
STREAMLIT_HOST=0.0.0.0
STREAMLIT_PORT=8501

# AirSim connection (set AIRSIM_HOST to your Unreal Engine machine IP)
AIRSIM_HOST=127.0.0.1
AIRSIM_PORT=41451

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Random seed (reproducible runs)
RANDOM_SEED=61
